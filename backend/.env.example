# SQLite (mặc định dev): một file backend/prisma/dev.db — không cần MySQL.
DATABASE_URL="file:./dev.db"

# MySQL (nếu bạn đổi schema Prisma sang mysql): ví dụ khớp docker-compose gốc dự án
# DATABASE_URL="mysql://root:123456@localhost:3306/tiki"

JWT_SECRET="your-secure-jwt-secret-key-here-min-32-characters"

# Mật khẩu tài khoản admin@demo.local khi chạy prisma seed (mặc định: admin123)
# ADMIN_SEED_PASSWORD="admin123"

PORT=4000
NODE_ENV=development

FRONTEND_URL="http://localhost:5173"
